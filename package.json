{
  "name": "file-organizer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prepare-dev.mjs && node scripts/launcher.mjs dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node scripts/launcher.mjs start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "node scripts/setup-db.mjs",
    "enable-startup": "node scripts/enable-startup.mjs",
    "disable-startup": "node scripts/disable-startup.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "chokidar": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "prisma": "^6.19.2",
    "tailwindcss": "^4"
  }
}
